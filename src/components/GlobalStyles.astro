---
// グローバルスタイルコンポーネント
// すべてのページで共通のスタイル設定を提供
---

<!-- サイト全体のフォント定義 -->
<link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Mincho:wght@300;400;500;700;900&display=swap" rel="stylesheet">

<style is:global>
  /* フォント変数定義 */
  :root {
    --font-primary: 'Zen Kaku Mincho', serif;
    --font-secondary: 'Source Sans Pro', sans-serif;
    --font-accent: 'Playfair Display', serif;
  }
  /* グローバルリンクスタイル */
  a {
    text-decoration: none;
    color: inherit;
  }
  
  /* フォーカス時のアウトラインを削除（アクセシビリティを考慮） */
  a:focus {
    outline: none;
  }
  
  /* ホバー時のスタイル（必要に応じてカスタマイズ可能） */
  a:hover {
    text-decoration: none;
  }
  
  /* アクティブ時のスタイル */
  a:active {
    text-decoration: none;
  }
  
  /* 訪問済みリンクのスタイル */
  a:visited {
    text-decoration: none;
  }
  
  /* グローバルHTML・BODYスタイル */
  html, body {
    height: 100%;
    line-height: 1.2;
    font-weight: 200;
    margin: 0;
    padding: 0;
    font-family: var(--font-primary);
    background: #fff;
    color: #222;
    color-scheme: light dark;
    transition: background 0.3s ease-in-out, color 0.3s ease-in-out;
  }


  /* ダークテーマ用グローバルスタイル */
  html.dark {
    background: #1F222D;
    color: #fff;
  }
  body.dark {
    background: #1F222D;
    color: #fff;
  }

  /* スクロールバーの矢印ボタンをサイト全体で非表示（WebKit/Blink） */
  *::-webkit-scrollbar-button,
  *::-webkit-scrollbar-button:single-button,
  *::-webkit-scrollbar-button:single-button:vertical:increment,
  *::-webkit-scrollbar-button:single-button:vertical:decrement,
  *::-webkit-scrollbar-button:single-button:horizontal:increment,
  *::-webkit-scrollbar-button:single-button:horizontal:decrement {
    display: none;
    width: 0;
    height: 0;
    background: transparent;
    background-image: none;
    border: none;
  }

  /* ===== レスポンシブ用グローバル変数（推奨: グローバルCSSとカスタムプロパティ） ===== */
  :root {
    /* ブレークポイント */
    --bp-lg: 1024px;
    --bp-md: 768px;
    --bp-sm: 480px;

    /* レイアウト基本スケール（ページ固有スタイルから参照可能） */
    --container-max: 1200px;
    --container-padding: 2rem; /* デフォルト（PC） */
  }

  /* タイポグラフィと余白の段階的縮小（モバイルファーストに寄せつつ安全な最小変更）
  max-widthの考え方はこの幅まではこの値を設定する、という意味。min-widthはその逆。 */
  @media (max-width: 1024px) {
    html { font-size: 15px; }
    :root { --container-padding: 1.5rem; }
  }

  @media (max-width: 768px) {
    html { font-size: 14px; }
    :root { --container-padding: 1rem; }
  }

  @media (max-width: 599px) {
    html { font-size: 12px; }
    :root { --container-padding: 0.75rem; }
    .moon-btn.entrance { display: none !important; }
    .moon-btn.menu { 
      top: 5vh !important;
      left: 10vw !important;
      width: 45px ;
      height: 45px ;
    }
    .moon-btn.menu svg {
      width: 45px !important;
      height: 45px !important;
    }
    .moon-btn.content {
      top: 5vh !important;
      left: 10vw !important;
      width: 45px !important;
      height: 45px !important;
    }
    .moon-btn.content svg {
      width: 45px !important;
      height: 45px !important;
    }
  }

</style>
